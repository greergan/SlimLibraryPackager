# Forgejo environment config — copy to .env and edit before running
# keep it in the same directory as the docker-compose.yml file

# Domain / hostname
FORGEJO_DOMAIN=forgejo

# PostgreSQL credentials
POSTGRES_DB=forgejo
POSTGRES_USER=forgejo
POSTGRES_PASSWORD=SECRET

FORGEJO__mailer__ENABLED=true
FORGEJO__mailer__PROTOCOL=smtp+starttls
FORGEJO__mailer__SMTP_ADDR=smtp.gmail.com
FORGEJO__mailer__SMTP_PORT=587
FORGEJO__mailer__USER=SECRET@gmail.com
FORGEJO__mailer__FROM=SECRET@gmail.com
FORGEJO__mailer__PASSWD=SECRET

FORGEJO_RUNNER_UUID=SECRET
FORGEJO_RUNNER_TOKEN=SECRET
